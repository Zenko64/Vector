{
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["**/components/ui/**"],
			"linter": { "enabled": false }
		}
	],
	"linter": {
		"rules": {
			"style": {
				"noNonNullAssertion": "warn"
			},
			"correctness": {
				"noUnusedFunctionParameters": "warn"
			}
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
